# Copy this file to .env, but never commit real values.
DATABRICKS_HOST=https://adb-0000000000000000.0.azuredatabricks.net
DATABRICKS_CONFIG_PROFILE=dev
BUNDLE_VAR_catalog=main

# Required only for staging/prod. This is the application/client ID, not a secret.
BUNDLE_VAR_service_principal_id=00000000-0000-0000-0000-000000000000
